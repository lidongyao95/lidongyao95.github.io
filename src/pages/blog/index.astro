---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import KnowledgeGraph from '../../components/KnowledgeGraph';
import { getCollection } from 'astro:content';
import { buildGraphData } from '../../utils/buildGraphData';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || a.id.localeCompare(b.id));

const graphData = buildGraphData();
const articleNodeIds = new Map<string, string[]>();

for (const node of graphData.nodes) {
  for (const articleId of node.articleIds) {
    const nodeIds = articleNodeIds.get(articleId) || [];
    nodeIds.push(node.id);
    articleNodeIds.set(articleId, nodeIds);
  }
}

const graphListData = JSON.stringify(
  graphData.nodes.map((node) => ({
    id: node.id,
    label: node.label,
    description: node.description,
    groupLabel: node.groupLabel,
    articleIds: node.articleIds,
  })),
).replace(/</g, '\\u003c');
---

<BaseLayout title="博客 — Douglas Li" description="关于软件工程和技术的思考。">
  <Nav />
  <main class="px-5 pb-20 pt-28 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8">
        <h1 class="mb-4 text-4xl font-bold text-accent">博客</h1>
        <p class="max-w-2xl text-gray-500">
          关于软件工程、AI 系统、模型训练和计算机图形学的思考。
        </p>
      </div>

      <section class="grid gap-6 lg:grid-cols-[minmax(0,3fr)_minmax(360px,2fr)] lg:items-start">
        <div>
          <div class="mb-3 flex items-center justify-between gap-4">
            <div>
              <h2 class="text-lg font-semibold text-white">知识图谱</h2>
              <p class="mt-1 text-sm text-gray-500">
                点击节点，在右侧查看它关联的一篇或多篇博客。
              </p>
            </div>
          </div>
          <KnowledgeGraph client:only="react" data={graphData} />
        </div>

        <aside
          class="rounded-lg border border-white/10 bg-bg-dark/45"
          aria-live="polite"
          aria-label="博客列表"
        >
          <div class="sticky top-24 max-h-none overflow-visible p-4 lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto">
            <div class="mb-4 border-b border-white/10 pb-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p id="blog-list-kicker" class="text-xs text-gray-600">全部文章</p>
                  <h2 id="blog-list-title" class="mt-1 text-xl font-semibold text-white">
                    时间倒序
                  </h2>
                </div>
                <button
                  id="blog-list-reset"
                  type="button"
                  hidden
                  class="rounded-md border border-white/10 px-3 py-1.5 text-xs text-gray-400 transition-colors hover:border-accent/40 hover:text-accent"
                >
                  返回全部
                </button>
              </div>
              <p id="blog-list-description" class="mt-3 text-sm leading-relaxed text-gray-500">
                默认显示所有博客。选择左侧节点后，这里会聚焦到该主题下的文章。
              </p>
              <p id="blog-list-count" class="mt-2 text-xs text-gray-600">
                共 {posts.length} 篇
              </p>
            </div>

            <div id="blog-list-items" class="divide-y divide-white/5">
              {posts.length === 0 ? (
                <p class="py-8 text-gray-600">暂无文章，敬请期待！</p>
              ) : (
                posts.map((post) => {
                  const nodeIds = articleNodeIds.get(post.id) || [];

                  return (
                    <a
                      href={`/blog/${post.id}`}
                      data-blog-item
                      data-article-id={post.id}
                      data-node-ids={nodeIds.join(',')}
                      class="block py-4 transition-colors hover:bg-white/[0.025]"
                    >
                      <span class="text-xs text-gray-600">
                        {post.data.date.toLocaleDateString('zh-CN', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })}
                      </span>
                      <h3 class="mt-1 text-base leading-snug text-white transition-colors hover:text-accent">
                        {post.data.title}
                      </h3>
                      {post.data.excerpt && (
                        <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-gray-500">
                          {post.data.excerpt}
                        </p>
                      )}
                    </a>
                  );
                })
              )}
            </div>
          </div>
        </aside>
      </section>
    </div>

    <script id="graph-list-data" type="application/json" set:html={graphListData}></script>
  </main>
  <Footer />
</BaseLayout>

<script>
  const dataEl = document.getElementById('graph-list-data');
  const nodes = JSON.parse(dataEl?.textContent || '[]');
  const kicker = document.getElementById('blog-list-kicker')!;
  const title = document.getElementById('blog-list-title')!;
  const description = document.getElementById('blog-list-description')!;
  const count = document.getElementById('blog-list-count')!;
  const reset = document.getElementById('blog-list-reset') as HTMLButtonElement;
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-blog-item]'));

  function showAll() {
    for (const item of items) item.style.display = '';
    kicker.textContent = '全部文章';
    title.textContent = '时间倒序';
    description.textContent = '默认显示所有博客。选择左侧节点后，这里会聚焦到该主题下的文章。';
    count.textContent = `共 ${items.length} 篇`;
    reset.hidden = true;
  }

  function showNode(node: any) {
    const selected = nodes.find((item: any) => item.id === node.id) || node;
    let visible = 0;

    for (const item of items) {
      const nodeIds = (item.dataset.nodeIds || '').split(',').filter(Boolean);
      const shouldShow = nodeIds.includes(selected.id);
      item.style.display = shouldShow ? '' : 'none';
      if (shouldShow) visible += 1;
    }

    kicker.textContent = selected.groupLabel || '相关主题';
    title.textContent = selected.label || '相关博客';
    description.textContent = selected.description || '该节点关联的博客如下。';
    count.textContent = `共 ${visible} 篇`;
    reset.hidden = false;
  }

  window.addEventListener('knowledge-graph-select', (event) => {
    const node = (event as CustomEvent).detail;
    if (!node) {
      showAll();
      return;
    }
    showNode(node);
  });

  reset.addEventListener('click', () => {
    showAll();
    window.dispatchEvent(new CustomEvent('knowledge-graph-select', { detail: null }));
  });
</script>

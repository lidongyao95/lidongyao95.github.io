---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<BaseLayout title={post.data.title} description={post.data.excerpt ?? '技术博客文章'}>
  <Nav />
  <main class="pt-28 pb-20 px-6">
    <div class="max-w-6xl mx-auto lg:grid lg:grid-cols-[13rem_minmax(0,48rem)] lg:gap-12 lg:items-start">
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block sticky top-28">
          <nav
            aria-label="文章章节目录"
            data-testid="post-toc"
            class="border-l border-white/10 pl-4"
          >
            <p class="text-xs font-semibold text-gray-500 mb-4 tracking-[0.2em] uppercase">
              目录
            </p>
            <ol class="space-y-2 text-sm">
              {tocHeadings.map((heading) => (
                <li class={heading.depth === 3 ? 'pl-4' : ''}>
                  <a
                    href={`#${heading.slug}`}
                    class="block text-gray-500 hover:text-accent transition-colors leading-snug break-words"
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}

      <article class="max-w-3xl min-w-0">
        <a href="/blog" class="text-accent text-sm mb-8 inline-block hover:underline">
          &larr; 返回博客
        </a>

        <span class="text-xs text-gray-600">
          {post.data.date.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </span>

        <h1 class="text-4xl font-bold text-white mt-2 mb-8">
          {post.data.title}
        </h1>

        <div class="article-body prose prose-invert max-w-none text-gray-400
          prose-headings:text-white prose-a:text-accent prose-strong:text-gray-200
          prose-code:text-accent prose-pre:bg-bg-dark prose-pre:border prose-pre:border-white/5">
          <Content />
        </div>
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-body :global(h2),
  .article-body :global(h3),
  .article-body :global(h4) {
    scroll-margin-top: 7rem;
  }
</style>

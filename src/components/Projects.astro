---
import Section from './Section.astro';

const projects = [
  {
    title: 'AI Skills for Teaching Practitioners',
    description: '面向教育工作者的 AI 技能实践指南，涵盖提示词工程、AI 辅助教学设计等。',
    tags: 'Python · AI · Education',
    gradient: 'from-[#1a1a2e] to-[#16213e]',
    url: 'https://github.com/lidongyao95/ai-skills-for-teaching-practitioners',
    icon: '🤖',
  },
  {
    title: 'EduScore Tracker',
    description: '教育评分追踪系统，支持学生成绩管理、数据分析与可视化报告。',
    tags: 'Python · Data · Web',
    gradient: 'from-[#0f3460] to-[#16213e]',
    url: 'https://github.com/lidongyao95/eduscore-tracker',
    icon: '📊',
  },
  {
    title: 'Work General Knowledge',
    description: '工作通用知识库，沉淀软件工程实践中的技术笔记、工具链配置与最佳实践。',
    tags: 'Python · Knowledge Base · Documentation',
    gradient: 'from-[#1a1a2e] to-[#0f3460]',
    url: 'https://github.com/lidongyao95/work_general_knowledge',
    icon: '📚',
  },
];
---

<Section id="projects" bg="medium">
  <h2 class="text-3xl font-bold text-accent mb-12 text-center">精选项目</h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {projects.map((project) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        data-tilt-card
        class="card-glow rounded-xl border border-white/5 bg-white/[0.02] overflow-hidden hover:border-accent/20 transition-all duration-300 group block"
      >
        <div class={`project-card-visual h-36 bg-gradient-to-br ${project.gradient} flex items-center justify-center`}>
          <span class="text-4xl opacity-40 group-hover:opacity-70 transition-opacity">{project.icon}</span>
        </div>
        <div class="project-card-copy p-5">
          <h3 class="font-semibold text-white mb-2 group-hover:text-accent transition-colors">
            {project.title}
          </h3>
          <p class="text-sm text-gray-500 mb-3 leading-relaxed">
            {project.description}
          </p>
          <span class="text-xs text-accent/80">{project.tags}</span>
        </div>
      </a>
    ))}
  </div>
</Section>

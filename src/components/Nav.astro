---
const links = [
  { href: '/', label: '首页' },
  { href: '/#about', label: '关于' },
  { href: '/#projects', label: '项目' },
  { href: '/blog', label: '博客' },
  { href: '/#contact', label: '联系' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-darkest/80 backdrop-blur-md border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-accent font-bold text-lg font-mono">&lt;DL /&gt;</a>

    <!-- Mobile hamburger -->
    <button
      class="md:hidden text-gray-400 hover:text-accent transition-colors p-2"
      aria-label="打开导航"
      aria-expanded="false"
      id="mobile-menu-toggle"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Desktop links -->
    <div class="hidden md:flex gap-8">
      {links.map((link) => (
        <a href={link.href} class="text-sm text-gray-400 hover:text-accent transition-colors">
          {link.label}
        </a>
      ))}
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-bg-darkest/95 backdrop-blur-sm border-t border-white/5">
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map((link) => (
        <a href={link.href} class="text-sm text-gray-400 hover:text-accent transition-colors py-2">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>
